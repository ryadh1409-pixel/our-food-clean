{
  "expo": {
    "name": "HalfOrder",
    "slug": "ourfood-clean",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "halforder",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.halforder.app",
      "buildNumber": "2",
      "associatedDomains": [
        "applinks:halforder.app",
        "applinks:www.halforder.app"
      ],
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "HalfOrder needs access to your photo library so you can choose a profile image.",
        "NSPhotoLibraryAddUsageDescription": "HalfOrder may save images you share only when you choose to save them.",
        "NSCameraUsageDescription": "HalfOrder needs camera access if you take a new photo for your profile.",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["halforder"],
            "CFBundleURLName": "HalfOrder Deep Link"
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.1087129301998-fpbmk5onqteqmgjsf91hq7cl7knobukf"
            ]
          }
        ]
      }
    },
    "android": {
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "halforder.app",
              "pathPrefix": "/order"
            },
            {
              "scheme": "https",
              "host": "halforder.app",
              "pathPrefix": "/join"
            },
            {
              "scheme": "https",
              "host": "halforder.app",
              "pathPrefix": "/terms"
            },
            {
              "scheme": "https",
              "host": "halforder.app",
              "pathPrefix": "/privacy"
            },
            {
              "scheme": "https",
              "host": "halforder.app",
              "pathPrefix": "/subscribe"
            },
            {
              "scheme": "https",
              "host": "www.halforder.app",
              "pathPrefix": "/order"
            },
            {
              "scheme": "https",
              "host": "www.halforder.app",
              "pathPrefix": "/join"
            },
            {
              "scheme": "https",
              "host": "www.halforder.app",
              "pathPrefix": "/terms"
            },
            {
              "scheme": "https",
              "host": "www.halforder.app",
              "pathPrefix": "/privacy"
            },
            {
              "scheme": "https",
              "host": "www.halforder.app",
              "pathPrefix": "/subscribe"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#4A90E2",
        "foregroundImage": "./assets/images/app-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.ourfoodclean"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "sounds": [],
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "HalfOrder needs your location to create and show orders on the map."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "HalfOrder needs access to your photo library so you can choose a profile image.",
          "cameraPermission": "HalfOrder needs camera access if you take a new photo for your profile."
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9b7ffbaf-659d-493c-a1bd-a695e2c2982c"
      },
      "iosAppStoreId": ""
    }
  }
}
