rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos: one file per signed-in user — `{uid}.jpg` only
    match /profiles/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && fileName == auth.uid + '.jpg';
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    /** Admin catalog images (`services/uploadImage.ts` → foodTemplates/). */
    match /foodTemplates/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (
          request.auth.uid == 'KT3LfXRsVgaH4LfRTQaexvj3CRn1'
          || (
            request.auth.token.email is string
            && request.auth.token.email == 'admin@ourfood.com'
          )
        );
    }
  }
}
