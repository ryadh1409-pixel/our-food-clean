rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    /** Must match constants/adminUid.ts, utils/admin.ts ADMIN_EMAILS, and users.role. */
    function isAdmin() {
      return isSignedIn()
        && (
          request.auth.uid == 'KT3LfXRsVgaH4LfRTQaexvj3CRn1'
          || (
            request.auth.token.email is string
            && (
              request.auth.token.email == 'admin@ourfood.com'
              || request.auth.token.email == 'support@halforder.app'
              || request.auth.token.email == 'ryadh1409@gmail.com'
            )
          )
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin'
          )
        );
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isCurrentUserRestricted() {
      return isSignedIn()
        && (
          currentUserData().banned == true
          || currentUserData().restricted == true
        );
    }

    function isNewUserForOrderLimits() {
      return currentUserData().totalOrdersCompleted is number
        && currentUserData().totalOrdersCompleted <= 3;
    }

    function canCreateOrderBySafetyLimits() {
      return !isCurrentUserRestricted()
        && (
          !isNewUserForOrderLimits()
          || (
            currentUserData().activeOrderCount is number
            && currentUserData().activeOrderCount < 1
          )
        );
    }

    /**
     * Lists are bounded to 20 entries (same cap as maxPeople / maxUsers in orders).
     * Firestore rules forbid recursive functions; use fixed-depth checks instead.
     */
    function listAllStrings(lst) {
      return lst is list
        && lst.size() <= 20
        && (lst.size() < 1 || lst[0] is string)
        && (lst.size() < 2 || lst[1] is string)
        && (lst.size() < 3 || lst[2] is string)
        && (lst.size() < 4 || lst[3] is string)
        && (lst.size() < 5 || lst[4] is string)
        && (lst.size() < 6 || lst[5] is string)
        && (lst.size() < 7 || lst[6] is string)
        && (lst.size() < 8 || lst[7] is string)
        && (lst.size() < 9 || lst[8] is string)
        && (lst.size() < 10 || lst[9] is string)
        && (lst.size() < 11 || lst[10] is string)
        && (lst.size() < 12 || lst[11] is string)
        && (lst.size() < 13 || lst[12] is string)
        && (lst.size() < 14 || lst[13] is string)
        && (lst.size() < 15 || lst[14] is string)
        && (lst.size() < 16 || lst[15] is string)
        && (lst.size() < 17 || lst[16] is string)
        && (lst.size() < 18 || lst[17] is string)
        && (lst.size() < 19 || lst[18] is string)
        && (lst.size() < 20 || lst[19] is string);
    }

    function participantsAllStrings(participants) {
      return listAllStrings(participants);
    }

    function usersAllStrings(users) {
      return listAllStrings(users);
    }

    function participantEntryMatchesUid(parts, uid, i) {
      return parts.size() > i
        && (
          (parts[i] is string && parts[i] == uid)
          || (
            parts[i] is map
            && parts[i].keys().hasAll(['userId', 'name'])
            && parts[i].userId == uid
          )
        );
    }

    /** HalfOrder / legacy: `users` uids or `participants` strings | maps with userId. */
    function participantListContainsUid(parts, uid) {
      return participantEntryMatchesUid(parts, uid, 0)
        || participantEntryMatchesUid(parts, uid, 1)
        || participantEntryMatchesUid(parts, uid, 2)
        || participantEntryMatchesUid(parts, uid, 3)
        || participantEntryMatchesUid(parts, uid, 4)
        || participantEntryMatchesUid(parts, uid, 5)
        || participantEntryMatchesUid(parts, uid, 6)
        || participantEntryMatchesUid(parts, uid, 7)
        || participantEntryMatchesUid(parts, uid, 8)
        || participantEntryMatchesUid(parts, uid, 9)
        || participantEntryMatchesUid(parts, uid, 10)
        || participantEntryMatchesUid(parts, uid, 11)
        || participantEntryMatchesUid(parts, uid, 12)
        || participantEntryMatchesUid(parts, uid, 13)
        || participantEntryMatchesUid(parts, uid, 14)
        || participantEntryMatchesUid(parts, uid, 15)
        || participantEntryMatchesUid(parts, uid, 16)
        || participantEntryMatchesUid(parts, uid, 17)
        || participantEntryMatchesUid(parts, uid, 18)
        || participantEntryMatchesUid(parts, uid, 19);
    }

    function isOrderMember(orderData) {
      return isSignedIn()
        && (
          request.auth.uid in orderData.get('users', [])
          || participantListContainsUid(orderData.get('participants', []), request.auth.uid)
        );
    }

    function validOrderHostDoc(h) {
      return h is map
        && h.keys().hasAll(['userId', 'name'])
        && h.userId is string
        && h.name is string
        && h.userId.size() > 0;
    }

    function validParticipantDoc(p) {
      return p is map
        && p.keys().hasAll(['userId', 'name'])
        && p.userId is string
        && p.name is string
        && p.userId.size() > 0;
    }

    function allParticipantDocsValid(parts) {
      return parts is list
        && parts.size() <= 20
        && (parts.size() < 1 || validParticipantDoc(parts[0]))
        && (parts.size() < 2 || validParticipantDoc(parts[1]))
        && (parts.size() < 3 || validParticipantDoc(parts[2]))
        && (parts.size() < 4 || validParticipantDoc(parts[3]))
        && (parts.size() < 5 || validParticipantDoc(parts[4]))
        && (parts.size() < 6 || validParticipantDoc(parts[5]))
        && (parts.size() < 7 || validParticipantDoc(parts[6]))
        && (parts.size() < 8 || validParticipantDoc(parts[7]))
        && (parts.size() < 9 || validParticipantDoc(parts[8]))
        && (parts.size() < 10 || validParticipantDoc(parts[9]))
        && (parts.size() < 11 || validParticipantDoc(parts[10]))
        && (parts.size() < 12 || validParticipantDoc(parts[11]))
        && (parts.size() < 13 || validParticipantDoc(parts[12]))
        && (parts.size() < 14 || validParticipantDoc(parts[13]))
        && (parts.size() < 15 || validParticipantDoc(parts[14]))
        && (parts.size() < 16 || validParticipantDoc(parts[15]))
        && (parts.size() < 17 || validParticipantDoc(parts[16]))
        && (parts.size() < 18 || validParticipantDoc(parts[17]))
        && (parts.size() < 19 || validParticipantDoc(parts[18]))
        && (parts.size() < 20 || validParticipantDoc(parts[19]));
    }

    function countParticipantUserId(parts, uid) {
      return (parts.size() > 0 && parts[0] is map && parts[0].userId == uid ? 1 : 0)
        + (parts.size() > 1 && parts[1] is map && parts[1].userId == uid ? 1 : 0)
        + (parts.size() > 2 && parts[2] is map && parts[2].userId == uid ? 1 : 0)
        + (parts.size() > 3 && parts[3] is map && parts[3].userId == uid ? 1 : 0)
        + (parts.size() > 4 && parts[4] is map && parts[4].userId == uid ? 1 : 0)
        + (parts.size() > 5 && parts[5] is map && parts[5].userId == uid ? 1 : 0)
        + (parts.size() > 6 && parts[6] is map && parts[6].userId == uid ? 1 : 0)
        + (parts.size() > 7 && parts[7] is map && parts[7].userId == uid ? 1 : 0)
        + (parts.size() > 8 && parts[8] is map && parts[8].userId == uid ? 1 : 0)
        + (parts.size() > 9 && parts[9] is map && parts[9].userId == uid ? 1 : 0)
        + (parts.size() > 10 && parts[10] is map && parts[10].userId == uid ? 1 : 0)
        + (parts.size() > 11 && parts[11] is map && parts[11].userId == uid ? 1 : 0)
        + (parts.size() > 12 && parts[12] is map && parts[12].userId == uid ? 1 : 0)
        + (parts.size() > 13 && parts[13] is map && parts[13].userId == uid ? 1 : 0)
        + (parts.size() > 14 && parts[14] is map && parts[14].userId == uid ? 1 : 0)
        + (parts.size() > 15 && parts[15] is map && parts[15].userId == uid ? 1 : 0)
        + (parts.size() > 16 && parts[16] is map && parts[16].userId == uid ? 1 : 0)
        + (parts.size() > 17 && parts[17] is map && parts[17].userId == uid ? 1 : 0)
        + (parts.size() > 18 && parts[18] is map && parts[18].userId == uid ? 1 : 0)
        + (parts.size() > 19 && parts[19] is map && parts[19].userId == uid ? 1 : 0);
    }

    /** HalfOrder: food-card swipe creates `orders` with `cardId` + `users` + `host`, string `participants`, `joinedAtMap`. */
    function isValidHalfOrderCreate() {
      return isSignedIn()
        && canCreateOrderBySafetyLimits()
        && !isCurrentUserRestricted()
        && request.resource.data.cardId is string
        && request.resource.data.cardId.size() > 0
        && request.resource.data.users is list
        && request.resource.data.users.size() == 1
        && usersAllStrings(request.resource.data.users)
        && request.auth.uid == request.resource.data.users[0]
        && request.resource.data.host is map
        && validOrderHostDoc(request.resource.data.host)
        && request.resource.data.host.userId == request.auth.uid
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 1
        && participantsAllStrings(request.resource.data.participants)
        && request.resource.data.participants[0] == request.auth.uid
        && request.resource.data.joinedAtMap is map
        && request.resource.data.joinedAtMap[request.auth.uid] is timestamp
        && (
          request.resource.data.status == 'waiting'
          || request.resource.data.status == 'active'
        )
        && (
          !request.resource.data.keys().hasAny(['matchWaitDeadlineAt'])
          || request.resource.data.matchWaitDeadlineAt is int
        )
        && request.resource.data.maxUsers is int
        && request.resource.data.maxUsers >= 2
        && request.resource.data.maxUsers <= 20
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.createdAt != null;
    }

    /** +1 `users`, string `participants` mirrors `users`, `joinedAtMap` gains joiner entry. Optional status -> matched. */
    function isHalfOrderParticipantIncrementalJoin() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && resource.data.cardId is string
        && resource.data.get('users', []).size() > 0
        && request.resource.data.users is list
        && usersAllStrings(request.resource.data.users)
        && request.resource.data.participants is list
        && participantsAllStrings(request.resource.data.participants)
        && request.resource.data.participants.size()
          == request.resource.data.users.size()
        && request.resource.data.users.size() == resource.data.get('users', []).size() + 1
        && request.resource.data.participants.size()
          == resource.data.get('participants', []).size() + 1
        && request.auth.uid in request.resource.data.users
        && !(request.auth.uid in resource.data.get('users', []))
        && participantListContainsUid(request.resource.data.participants, request.auth.uid)
        && !participantListContainsUid(resource.data.get('participants', []), request.auth.uid)
        && request.resource.data.joinedAtMap is map
        && request.resource.data.joinedAtMap[request.auth.uid] is timestamp
        && request.resource.data.users.size() <= resource.data.get('maxUsers', 2)
        && request.resource.data.cardId == resource.data.cardId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.get('hostId', '')
          == resource.data.get('hostId', '')
        && request.resource.data.maxUsers == resource.data.maxUsers
        && (
          !resource.data.keys().hasAny(['host'])
          || request.resource.data.host == resource.data.host
        )
        && (
          (
            request.resource.data.diff(resource.data).changedKeys()
              .hasOnly(['users', 'participants', 'joinedAtMap'])
            && request.resource.data.status == resource.data.status
          )
          || (
            request.resource.data.diff(resource.data).changedKeys()
              .hasOnly(['users', 'participants', 'joinedAtMap', 'status'])
            && request.resource.data.status == 'matched'
            && (
              resource.data.status == 'waiting'
              || resource.data.status == 'active'
            )
          )
        );
    }

    /** Empty participants, one user -> two users, two string participant ids, `host`, joiner in `joinedAtMap`. */
    function isHalfOrderParticipantBootstrapJoin() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && resource.data.cardId is string
        && resource.data.get('participants', []).size() == 0
        && resource.data.get('users', []).size() == 1
        && request.resource.data.users is list
        && request.resource.data.users.size() == 2
        && usersAllStrings(request.resource.data.users)
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && participantsAllStrings(request.resource.data.participants)
        && request.auth.uid in request.resource.data.users
        && !(request.auth.uid in resource.data.get('users', []))
        && request.resource.data.participants[0] == resource.data.users[0]
        && request.resource.data.participants[1] == request.auth.uid
        && validOrderHostDoc(request.resource.data.host)
        && request.resource.data.host.userId == resource.data.users[0]
        && request.resource.data.joinedAtMap is map
        && request.resource.data.joinedAtMap[request.auth.uid] is timestamp
        && request.resource.data.cardId == resource.data.cardId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.get('hostId', '')
          == resource.data.get('hostId', '')
        && request.resource.data.maxUsers == resource.data.maxUsers
        && (
          (
            request.resource.data.diff(resource.data).changedKeys()
              .hasOnly(['users', 'participants', 'host', 'joinedAtMap'])
            && request.resource.data.status == resource.data.status
          )
          || (
            request.resource.data.diff(resource.data).changedKeys()
              .hasOnly(['users', 'participants', 'host', 'joinedAtMap', 'status'])
            && request.resource.data.status == 'matched'
            && (
              resource.data.status == 'waiting'
              || resource.data.status == 'active'
            )
          )
        );
    }

    /** HalfOrder member cancels the match (notify others via Cloud Function). */
    function isHalfOrderCancelUpdate() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && resource.data.cardId is string
        && resource.data.cardId.size() > 0
        && (
          resource.data.status == 'waiting'
          || resource.data.status == 'matched'
          || resource.data.status == 'active'
        )
        && request.resource.data.status == 'cancelled'
        && request.auth.uid in resource.data.get('users', [])
        && request.resource.data.cancelledBy == request.auth.uid
        && request.resource.data.users == resource.data.users
        && request.resource.data.cardId == resource.data.cardId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.get('hostId', '')
          == resource.data.get('hostId', '')
        && request.resource.data.maxUsers == resource.data.maxUsers
        && request.resource.data.participants == resource.data.participants
        && (
          !resource.data.keys().hasAny(['host'])
          || request.resource.data.host == resource.data.host
        )
        && request.resource.data.cancelledAt != null
        && (
          request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['status', 'cancelledBy', 'cancelledAt'])
          || request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['status', 'cancelledBy', 'cancelledAt', 'cancelReason'])
        )
        && (
          !request.resource.data.keys().hasAny(['cancelReason'])
          || request.resource.data.cancelReason is string
        );
    }

    /** matched -> active when opening chat. */
    function isHalfOrderMarkActiveUpdate() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && resource.data.cardId is string
        && resource.data.cardId.size() > 0
        && resource.data.status == 'matched'
        && request.resource.data.status == 'active'
        && request.auth.uid in resource.data.get('users', [])
        && request.resource.data.users == resource.data.users
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.cardId == resource.data.cardId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.get('hostId', '')
          == resource.data.get('hostId', '')
        && request.resource.data.maxUsers == resource.data.maxUsers
        && (
          !resource.data.keys().hasAny(['host'])
          || request.resource.data.host == resource.data.host
        )
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status']);
    }

    /** Mark half order done. */
    function isHalfOrderCompleteUpdate() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && resource.data.cardId is string
        && resource.data.cardId.size() > 0
        && (
          resource.data.status == 'matched'
          || resource.data.status == 'active'
        )
        && request.resource.data.status == 'completed'
        && request.auth.uid in resource.data.get('users', [])
        && request.resource.data.users == resource.data.users
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.cardId == resource.data.cardId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.get('hostId', '')
          == resource.data.get('hostId', '')
        && request.resource.data.maxUsers == resource.data.maxUsers
        && (
          !resource.data.keys().hasAny(['host'])
          || request.resource.data.host == resource.data.host
        )
        && request.resource.data.completedAt != null
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['status', 'completedAt']);
    }

    function isOrderMemberByOrderId(orderId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/orders/$(orderId))
        && request.auth.uid in get(/databases/$(database)/documents/orders/$(orderId)).data.get('users', []);
    }

    /** Exactly-once: pair-join push ack via `notified` (client sends Expo push). */
    function isOrderPairJoinNotifiedUpdate() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && resource.data.cardId is string
        && resource.data.cardId.size() > 0
        && resource.data.get('users', []).size() == 2
        && request.auth.uid in resource.data.get('users', [])
        && resource.data.get('notified', false) != true
        && request.resource.data.notified == true
        && (
          request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['notified', 'notifiedAt'])
          || (
            request.resource.data.diff(resource.data).changedKeys()
              .hasOnly(['notified', 'notifiedAt', 'notificationSent'])
            && request.resource.data.notificationSent == true
          )
        )
        && request.resource.data.users == resource.data.users
        && request.resource.data.cardId == resource.data.cardId
        && request.resource.data.status == resource.data.status
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.get('hostId', '')
          == resource.data.get('hostId', '')
        && request.resource.data.maxUsers == resource.data.maxUsers
        && request.resource.data.participants == resource.data.participants
        && (
          !resource.data.keys().hasAny(['host'])
          || request.resource.data.host == resource.data.host
        );
    }

    function orderLinkTargetsCard(orderId, cardId) {
      return exists(/databases/$(database)/documents/orders/$(orderId))
        && get(/databases/$(database)/documents/orders/$(orderId)).data.cardId == cardId;
    }

    function requesterInOrderUsers(orderId) {
      return request.auth.uid
        in get(/databases/$(database)/documents/orders/$(orderId)).data.get('users', []);
    }

    /** First link: set `food_cards.orderId` to a new HalfOrder doc (caller must be in order.users). */
    function isValidFoodCardOrderIdLink(cardId) {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['orderId'])
        && request.resource.data.orderId is string
        && request.resource.data.orderId.size() > 0
        && (
          !resource.data.keys().hasAny(['orderId'])
          || resource.data.orderId == null
        )
        && orderLinkTargetsCard(request.resource.data.orderId, cardId)
        && requesterInOrderUsers(request.resource.data.orderId);
    }

    /** Tinder-style like: only `usersAccepted` changes, +1 size, cap by maxPeople. */
    function isSwipeAcceptUpdate() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['usersAccepted'])
        && request.resource.data.usersAccepted is list
        && request.auth.uid in request.resource.data.usersAccepted
        && !(request.auth.uid in resource.data.get('usersAccepted', []))
        && request.resource.data.usersAccepted.size()
          == resource.data.get('usersAccepted', []).size() + 1
        && request.resource.data.usersAccepted.size()
          <= resource.data.get('maxPeople', 2);
    }

    function orderSwipeAcceptList(orderId) {
      return get(/databases/$(database)/documents/orders/$(orderId)).data.get('usersAccepted', []);
    }

    function isValidFoodMatchCreate(matchDocId) {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && request.resource.data.orderId is string
        && request.resource.data.users is list
        && request.resource.data.users.size() == 2
        && request.resource.data.status == 'matched'
        && request.resource.data.createdAt != null
        && request.auth.uid in request.resource.data.users
        && request.resource.data.users[0] < request.resource.data.users[1]
        && matchDocId
          == request.resource.data.orderId + '_' + request.resource.data.users[0] + '_' + request.resource.data.users[1]
        && orderSwipeAcceptList(request.resource.data.orderId).size() >= 2
        && request.resource.data.users[0]
          in orderSwipeAcceptList(request.resource.data.orderId)
        && request.resource.data.users[1]
          in orderSwipeAcceptList(request.resource.data.orderId);
    }

    function isValidOrderCreate() {
      return isSignedIn()
        && canCreateOrderBySafetyLimits()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.maxPeople is number
        && request.resource.data.maxPeople >= 2
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 1
        && participantsAllStrings(request.resource.data.participants)
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.joinedAtMap is map
        && request.resource.data.joinedAtMap[request.auth.uid] is timestamp
        && request.resource.data.usersAccepted is list
        && request.resource.data.usersAccepted.size() == 0
        && request.resource.data.foodName is string
        && request.resource.data.image is string
        && request.resource.data.pricePerPerson is number
        && request.resource.data.totalPrice is number
        && request.resource.data.createdAt != null;
    }

    function orderCreatorUidFromDoc(data) {
      return data.get(
        'createdBy',
        data.get('userId', data.get('hostId', ''))
      );
    }

    function isParticipantsJoinUpdate() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['participants', 'joinedAtMap', 'startedAt', 'expiresAt'])
        && request.resource.data.participants is list
        && participantsAllStrings(request.resource.data.participants)
        && request.resource.data.participants.size()
          == resource.data.get('participants', []).size() + 1
        && request.auth.uid in request.resource.data.participants
        && !(request.auth.uid in resource.data.get('participants', []))
        && request.resource.data.joinedAtMap is map
        && request.resource.data.joinedAtMap[request.auth.uid] is timestamp
        && request.resource.data.participants.size()
          <= resource.data.get('maxPeople', 2)
        && (
          !request.resource.data.diff(resource.data).changedKeys()
            .hasAny(['startedAt', 'expiresAt'])
          || (
            request.resource.data.startedAt is timestamp
            && request.resource.data.expiresAt is timestamp
          )
        );
    }

    function isParticipantsJoinWithExtrasUpdate() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['participants', 'joinedAtMap', 'status', 'user2Id', 'user2Name', 'startedAt', 'expiresAt'])
        && request.resource.data.participants is list
        && participantsAllStrings(request.resource.data.participants)
        && request.resource.data.participants.size()
          == resource.data.get('participants', []).size() + 1
        && request.auth.uid in request.resource.data.participants
        && !(request.auth.uid in resource.data.get('participants', []))
        && request.resource.data.joinedAtMap is map
        && request.resource.data.joinedAtMap[request.auth.uid] is timestamp
        && request.resource.data.participants.size()
          <= resource.data.get('maxPeople', 2)
        && (
          !request.resource.data.diff(resource.data).changedKeys()
            .hasAny(['startedAt', 'expiresAt'])
          || (
            request.resource.data.startedAt is timestamp
            && request.resource.data.expiresAt is timestamp
          )
        );
    }

    function isJoinedAtMapBackfillUpdate() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['joinedAtMap'])
        && request.resource.data.participants == resource.data.participants
        && request.auth.uid in resource.data.get('participants', [])
        && request.resource.data.joinedAtMap is map
        && request.resource.data.joinedAtMap[request.auth.uid] is timestamp;
    }

    function isParticipantsLeaveUpdate() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && orderCreatorUidFromDoc(resource.data) != request.auth.uid
        && (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['participants', 'joinedAtMap'])
          || request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['participants', 'joinedAtMap', 'status'])
        )
        && request.resource.data.participants is list
        && participantsAllStrings(request.resource.data.participants)
        && request.resource.data.participants.size()
          == resource.data.get('participants', []).size() - 1
        && !(request.auth.uid in request.resource.data.participants)
        && request.auth.uid in resource.data.get('participants', []);
    }

    function isOrderTypingUpdate() {
      return isSignedIn()
        && request.auth.uid in resource.data.get('participants', [])
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['typing']);
    }

    function isCreatorOnlyNonJoinUpdate() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && resource.data.createdBy == request.auth.uid
        && !request.resource.data.diff(resource.data).changedKeys().hasAny([
          'participants',
          'joinedAtMap',
          'usersAccepted',
          'typing'
        ])
        && (
          resource.data.status != 'completed'
          || request.resource.data.status == resource.data.status
        )
        && (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(['status'])
          || request.resource.data.status != 'cancelled'
          || (
            currentUserData().cancellationCount24h is number
            && currentUserData().cancellationCount24h < 3
          )
        );
    }

    function isMarkOrderExpiredUpdate() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status'])
        && resource.data.status in ['open', 'matched', 'full']
        && request.resource.data.status == 'expired'
        && request.auth.uid in resource.data.get('participants', []);
    }

    /** Open swipe-deck food card status. */
    function foodCardOpenStatus(s) {
      return s == 'active';
    }

    function isValidFoodCardJoinUpdate() {
      return isSignedIn()
        && (
          (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['user1', 'user2', 'status', 'createdAt'])
            && foodCardOpenStatus(resource.data.status)
            && (
              (
                resource.data.user1 == null
                && request.resource.data.user1.uid == request.auth.uid
                && foodCardOpenStatus(request.resource.data.status)
              )
              || (
                resource.data.user1.uid is string
                && resource.data.user1.uid != request.auth.uid
                && resource.data.user2 == null
                && request.resource.data.user2.uid == request.auth.uid
                && request.resource.data.status == 'matched'
              )
            )
          )
        );
    }

    match /reports/{reportId} {
      allow create: if isSignedIn()
        && !isCurrentUserRestricted()
        && request.auth.uid == request.resource.data.reporterId
        && request.resource.data.reportedUserId is string
        && request.resource.data.reportedUserId.size() > 0
        && request.resource.data.reportedUserId != request.auth.uid
        && request.resource.data.contentId is string
        && request.resource.data.contentId.size() > 0
        && request.resource.data.reason is string
        && (
          request.resource.data.reason == 'spam'
          || request.resource.data.reason == 'abuse'
          || request.resource.data.reason == 'inappropriate'
        )
        && request.resource.data.createdAt == request.time
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'userId',
          'reporterId',
          'reportedUserId',
          'contentId',
          'reason',
          'createdAt',
        ]);
      allow read, update, delete: if isAdmin();
    }
    match /support_chats/{userId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      allow write: if false;
    }
    match /support_chats/{userId}/messages/{messageId} {
      allow read, write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
    }
    match /ratings/{ratingId} {
      allow create: if request.auth != null
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.orderId is string
        && request.resource.data.toUserId is string
        && request.resource.data.comment is string
        && request.resource.data.createdAt != null
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    /** Assistant chat → product feedback (one doc per message; onCreate email to support). */
    match /feedback/{feedbackId} {
      allow create: if request.auth != null
        && !isCurrentUserRestricted()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userName is string
        && request.resource.data.message is string
        && (
          request.resource.data.sentiment == 'positive'
          || request.resource.data.sentiment == 'negative'
          || request.resource.data.sentiment == 'neutral'
        )
        && request.resource.data.source == 'assistant_chat'
        && request.resource.data.createdAt == request.time
        && (
          !request.resource.data.keys().hasAny(['userEmail'])
          || request.resource.data.userEmail is string
        );
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    /**
     * Email invite row → Cloud Function `sendOrderInvite` (nodemailer).
     * Inviter must be a member of the order (`users` or string `participants`).
     */
    match /invites/{inviteId} {
      allow create: if isSignedIn()
        && !isCurrentUserRestricted()
        && request.resource.data.keys().hasAll([
          'email',
          'orderId',
          'inviterName',
          'inviterId',
          'createdAt',
        ])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.orderId is string
        && request.resource.data.orderId.size() > 0
        && request.resource.data.inviterName is string
        && request.resource.data.inviterId == request.auth.uid
        && request.resource.data.createdAt == request.time
        && exists(/databases/$(database)/documents/orders/$(request.resource.data.orderId))
        && (
          request.auth.uid in get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.get('users', [])
          || request.auth.uid in get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.get('participants', [])
          || participantListContainsUid(
            get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.get('participants', []),
            request.auth.uid
          )
        );
      allow read: if isAdmin()
        || (
          isSignedIn()
          && resource.data.inviterId == request.auth.uid
        );
      allow update, delete: if false;
    }

    /** First pair-join on a half-order: one doc per orderId (idempotency). */
    match /referrals/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && !isCurrentUserRestricted()
        && !exists(/databases/$(database)/documents/referrals/$(orderId))
        && request.resource.data.keys().hasAll([
          'inviterId',
          'invitedUserId',
          'orderId',
          'createdAt',
        ])
        && request.resource.data.orderId == orderId
        && request.resource.data.invitedUserId == request.auth.uid
        && request.resource.data.inviterId is string
        && request.resource.data.inviterId != request.auth.uid
        && request.resource.data.inviterId != request.resource.data.invitedUserId
        && request.resource.data.createdAt == request.time
        && request.auth.uid in get(/databases/$(database)/documents/orders/$(orderId)).data.get('users', [])
        && request.resource.data.inviterId in get(/databases/$(database)/documents/orders/$(orderId)).data.get('users', [])
        && get(/databases/$(database)/documents/orders/$(orderId)).data.get('users', []).size() >= 2;
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      match /messages/{messageId} {
        allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      }
      /** Expo push token doc(s): e.g. `pushToken/default`. */
      match /pushToken/{docId} {
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
      match /fcmToken/{docId} {
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
      /** Block list: doc id = blocked user's uid. */
      match /blockedUsers/{blockedId} {
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow create: if request.auth != null
          && request.auth.uid == userId
          && blockedId is string
          && blockedId.size() > 8
          && blockedId != userId
          && request.resource.data.blockedUserId == blockedId
          && request.resource.data.keys().hasOnly(['blockedUserId', 'createdAt'])
          && request.resource.data.createdAt == request.time;
        allow update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.blockedUserId == resource.data.blockedUserId
          && request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
      /** Pending host credit (+2) from a pair-join referral; host claims via client. */
      match /referralInbox/{orderId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if isSignedIn()
          && !isCurrentUserRestricted()
          && request.auth.uid == request.resource.data.fromUid
          && request.auth.uid != userId
          && request.resource.data.credits == 2
          && request.resource.data.orderId == orderId
          && request.resource.data.createdAt == request.time
          && exists(/databases/$(database)/documents/referrals/$(orderId))
          && get(/databases/$(database)/documents/referrals/$(orderId)).data.invitedUserId
            == request.auth.uid
          && get(/databases/$(database)/documents/referrals/$(orderId)).data.inviterId == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
        allow update: if false;
      }
    }
    function isChatDocMember(chatId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/chats/$(chatId))
        && (
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.get('participants', [])
          || request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.get('users', [])
        );
    }

    function isChatUsersAppendUpdate(chatId) {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && request.resource.data.orderId == chatId
        && request.resource.data.orderId == resource.data.orderId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['users'])
        && request.resource.data.users is list
        && usersAllStrings(request.resource.data.users)
        && resource.data.get('users', []).size() > 0
        && request.resource.data.users.size() == resource.data.get('users', []).size() + 1
        && request.auth.uid in request.resource.data.users
        && !(request.auth.uid in resource.data.get('users', []));
    }

    function isChatLastMessagePatch(chatId) {
      return isSignedIn()
        && isChatDocMember(chatId)
        && request.resource.data.orderId == resource.data.orderId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['lastMessage', 'lastMessageAt']);
    }

    function isChatReadsUpdate(chatId) {
      return isSignedIn()
        && isChatDocMember(chatId)
        && request.resource.data.orderId == resource.data.orderId
        && request.resource.data.users == resource.data.users
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.reads is map
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['reads'])
        && (
          !resource.data.keys().hasAny(['reads'])
          || (
            resource.data.reads is map
            && request.resource.data.reads.keys().hasAll(resource.data.reads.keys())
          )
        );
    }

    match /chats/{chatId} {
      allow read: if isAdmin() || isChatDocMember(chatId);
      allow create: if isAdmin()
        || (
          isSignedIn()
          && !isCurrentUserRestricted()
          && request.resource.data.orderId == chatId
          && request.resource.data.users is list
          && request.resource.data.users.size() >= 1
          && usersAllStrings(request.resource.data.users)
          && request.auth.uid in request.resource.data.users
          && request.resource.data.createdAt != null
        );
      allow update: if isAdmin()
        || isChatUsersAppendUpdate(chatId)
        || isChatLastMessagePatch(chatId)
        || isChatReadsUpdate(chatId);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAdmin() || isChatDocMember(chatId);
        allow create: if isAdmin()
          || (
            isSignedIn()
            && request.resource.data.text is string
            && request.resource.data.createdAt != null
            && (
              request.resource.data.senderId == 'system'
              || request.resource.data.sender == 'ai'
              || (
                request.resource.data.senderId == request.auth.uid
                && isChatDocMember(chatId)
              )
            )
          );
        allow update, delete: if isAdmin();
      }
    }
    match /messages/{messageId} {
      allow read: if isAdmin()
        || (
          request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(resource.data.chatId)).data.participants
        );
      allow create: if isAdmin()
        || (
          request.auth != null
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(request.resource.data.chatId)).data.participants
        );
      allow update, delete: if isAdmin();
    }
    match /calls/{callId} {
      allow create: if request.auth != null && request.resource.data.callerId == request.auth.uid;
      allow read, update: if request.auth != null
        && (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow delete: if false;
    }
    match /complaints/{complaintId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }
    match /admins/{adminId} {
      allow read, write: if false;
    }
    match /notifications/{notificationId} {
      allow create, read: if request.auth != null;
      allow update, delete: if false;
    }
    match /notification_logs/{logId} {
      allow create, read: if request.auth != null;
      allow update, delete: if false;
    }
    match /user_activity/{activityId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }
    match /broadcasts/{broadcastId} {
      allow create, read: if isAdmin();
      allow update, delete: if false;
    }

    /** Admin broadcast push history (mobile admin app). */
    match /admin_notifications/{notificationId} {
      allow create: if isAdmin()
        && request.resource.data.title is string
        && request.resource.data.message is string
        && request.resource.data.sentToCount is int
        && request.resource.data.sentToCount >= 0
        && request.resource.data.createdAt == request.time;
      allow read: if isAdmin();
      allow update, delete: if false;
    }
    match /blocks/{blockId} {
      allow create: if request.auth != null && request.resource.data.blockerId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.blockerId == request.auth.uid || resource.data.blockedUserId == request.auth.uid);
      allow update: if false;
      allow delete: if request.auth != null
        && (resource.data.blockerId == request.auth.uid || resource.data.blockedUserId == request.auth.uid);
    }
    match /matches/{matchId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.users;
      allow create: if isValidFoodMatchCreate(matchId);
      allow update, delete: if false;
    }
    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isValidOrderCreate() || isValidHalfOrderCreate() || isAdmin();
      allow update: if isAdmin()
        || isParticipantsJoinUpdate()
        || isParticipantsJoinWithExtrasUpdate()
        || isJoinedAtMapBackfillUpdate()
        || isParticipantsLeaveUpdate()
        || isOrderTypingUpdate()
        || isCreatorOnlyNonJoinUpdate()
        || isSwipeAcceptUpdate()
        || isMarkOrderExpiredUpdate()
        || isHalfOrderParticipantIncrementalJoin()
        || isHalfOrderParticipantBootstrapJoin()
        || isHalfOrderCancelUpdate()
        || isHalfOrderMarkActiveUpdate()
        || isHalfOrderCompleteUpdate()
        || isOrderPairJoinNotifiedUpdate();
      allow delete: if isAdmin()
        || (
          request.auth != null
          && resource.data.createdBy == request.auth.uid
        );

      match /order_members/{memberId} {
        allow read: if isAdmin() || isOrderMemberByOrderId(orderId);
        allow create, update: if isAdmin()
          || (
            !isCurrentUserRestricted()
            && request.auth.uid == memberId
            && isOrderMemberByOrderId(orderId)
          );
        allow delete: if isAdmin();
      }

      match /messages/{messageId} {
        allow read, write: if isAdmin()
          || isOrderMember(
            get(/databases/$(database)/documents/orders/$(orderId)).data
          );
      }

      match /ratings/{ratingId} {
        allow read, write: if isAdmin()
          || (
            isSignedIn()
            && ratingId == request.auth.uid
            && isOrderMember(
              get(/databases/$(database)/documents/orders/$(orderId)).data
            )
          );
      }
    }

    match /food_cards/{cardId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || isValidFoodCardOrderIdLink(cardId)
        || isValidFoodCardJoinUpdate();
    }

    /** Public catalog (max 10 docs enforced in app). Read: any signed-in user. Write: admin only. */
    match /foodTemplates/{templateId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
